{
  "name": "apk-installer",
  "version": "2.0.0",
  "description": "Instalador de APK no Android — Interface gráfica",
  "repository": {
    "type": "git",
    "url": "https://github.com/luisgustavo-picpay/apk-installer.git"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis",
    "build:all": "electron-builder --mac dmg --win nsis"
  },
  "author": "Luis Gustavo",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.apkinstaller.app",
    "productName": "APK Installer",
    "icon": "assets/icon.png",
    "afterPack": "./scripts/afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png"
    },
    "dmg": {
      "title": "APK Installer",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "shortcutName": "APK Installer"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  }
}
